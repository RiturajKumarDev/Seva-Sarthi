<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="70dp"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="bottom"
    android:layout_marginEnd="12dp">

    <TextView
        android:id="@+id/tvCreated"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="25"
        android:textSize="10sp"
        android:textColor="@color/logo_gold"
        android:layout_marginBottom="4dp"
        android:layout_gravity="center" />

    <View
        android:id="@+id/barCreated"
        android:layout_width="28dp"
        android:layout_height="50dp"
        android:layout_gravity="center"
        android:layout_margin="2dp"
        android:background="@drawable/bar_gradient_gold" />

    <TextView
        android:id="@+id/tvResolved"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="22"
        android:textSize="10sp"
        android:textColor="@color/logo_green"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:layout_gravity="center" />

    <View
        android:id="@+id/barResolved"
        android:layout_width="28dp"
        android:layout_height="44dp"
        android:layout_gravity="center"
        android:layout_margin="2dp"
        android:background="@drawable/bar_gradient_green" />

    <TextView
        android:id="@+id/tvDay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mon"
        android:textSize="11sp"
        android:textColor="@color/logo_white"
        android:layout_marginTop="8dp"
        android:layout_gravity="center" />

</LinearLayout>