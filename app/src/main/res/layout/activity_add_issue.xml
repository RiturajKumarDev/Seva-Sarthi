<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_gradient_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/logo_dark_blue"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:titleTextColor="@color/logo_white" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="32dp">

            <!-- Header -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Register New Issue"
                android:textColor="@color/logo_white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="Fill in the details below"
                android:textColor="@color/logo_gold_light"
                android:textSize="14sp" />

            <!-- Error Text -->
            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center"
                android:text=""
                android:textColor="@color/logo_orange"
                android:textSize="12sp"
                android:visibility="gone" />

            <!-- Problem Details Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#1AFFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="Issue Classification"
                        android:textColor="@color/logo_gold"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <!-- Problem Type -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Problem Type"
                        android:textColor="@color/logo_white"
                        android:textSize="14sp" />

                    <Spinner
                        android:id="@+id/spinnerProblemType"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/spinner_background"
                        android:entries="@array/department_category" />

                    <!-- Issue Type -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Issue"
                        android:textColor="@color/logo_white"
                        android:textSize="14sp" />

                    <Spinner
                        android:id="@+id/spinnerIssueType"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/spinner_background" />

                    <!-- Priority -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Priority Level"
                        android:textColor="@color/logo_white"
                        android:textSize="14sp" />

                    <Spinner
                        android:id="@+id/spinnerPriority"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/spinner_background" />

                    <LinearLayout
                        android:id="@+id/selectWorkerBox"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="Select Worker"
                            android:textColor="@color/logo_white"
                            android:textSize="14sp" />

                        <Spinner
                            android:id="@+id/spinnerSelectWorker"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:background="@drawable/spinner_background" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#1AFFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="Problem Details"
                        android:textColor="@color/logo_gold"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <!-- Problem Title -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilProblemTitle"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Problem Title"
                        app:boxStrokeColor="@color/logo_gold"
                        app:hintTextColor="@color/logo_gold_light">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etProblemTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/logo_white" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Problem Description -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilProblemDescription"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Problem Description"
                        app:hintTextColor="@color/logo_gold_light">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etProblemDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="top"
                            android:minLines="3"
                            android:textColor="@color/logo_white" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Location -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilLocation"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Location / Address"
                        app:hintTextColor="@color/logo_gold_light">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/logo_white" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Select Founder"
                        android:textColor="@color/logo_white"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <Spinner
                        android:id="@+id/spinnerFounder"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/spinner_background"
                        android:visibility="gone" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Issue Classification Card -->

            <!-- Submit Button -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmitIssue"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Register Issue"
                    android:textColor="@color/logo_dark_blue"
                    android:textSize="16sp"
                    app:backgroundTint="@color/logo_gold"
                    app:cornerRadius="28dp" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:visibility="gone" />
            </FrameLayout>

        </LinearLayout>
    </LinearLayout>
</ScrollView>