<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer circle -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#1AFFFFFF" />
            <stroke
                android:width="2dp"
                android:color="@color/logo_gold_light" />
            <size
                android:width="60dp"
                android:height="60dp" />
        </shape>
    </item>

    <!-- Inner circle -->
    <item
        android:bottom="15dp"
        android:left="15dp"
        android:right="15dp"
        android:top="15dp">
        <shape android:shape="oval">
            <solid android:color="@color/logo_gold" />
        </shape>
    </item>

    <!-- SevaMitra 'S' letter -->
    <item
        android:bottom="18dp"
        android:left="25dp"
        android:right="25dp"
        android:top="18dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/logo_dark_blue" />
        </shape>
    </item>
</layer-list>