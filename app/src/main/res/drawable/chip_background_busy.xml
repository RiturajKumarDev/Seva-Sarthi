<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Selected State -->
    <item android:state_checked="true">
        <shape>
            <solid android:color="@color/logo_orange" />
            <corners android:radius="32dp" />
            <stroke
                android:width="1dp"
                android:color="@color/logo_orange_dark" />
        </shape>
    </item>

    <!-- Pressed State -->
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/logo_orange_dark" />
            <corners android:radius="32dp" />
            <stroke
                android:width="1dp"
                android:color="@color/logo_orange" />
        </shape>
    </item>

    <!-- Default State -->
    <item>
        <shape>
            <solid android:color="#1AFFFFFF" />
            <corners android:radius="32dp" />
            <stroke
                android:width="1dp"
                android:color="@color/logo_orange" />
        </shape>
    </item>
</selector>